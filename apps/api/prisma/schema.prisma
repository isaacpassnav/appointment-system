// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

enum NotificationChannel {
  EMAIL
  WHATSAPP
}

enum NotificationStatus {
  QUEUED
  SENT
  FAILED
}

enum UserRole {
  SUPERADMIN
  RESELLER
  ADMIN
  STAFF
  CLIENT
}

enum TenantRole {
  BUSINESS_ADMIN
  STAFF
  CLIENT
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
}

enum TenantMemberStatus {
  ACTIVE
  INVITED
  SUSPENDED
}

model User {
  id               String        @id @default(uuid()) @db.Uuid
  email            String        @unique
  passwordHash     String
  fullName         String
  phone            String?       @db.VarChar(30)
  timezone         String        @default("UTC")
  role             UserRole      @default(CLIENT)
  refreshTokenHash String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  appointments     Appointment[]
  memberships      TenantMember[]
  resellerTenants  Tenant[]      @relation("ResellerTenants")
}

model Tenant {
  id          String        @id @default(uuid()) @db.Uuid
  name        String
  slug        String        @unique
  status      TenantStatus @default(ACTIVE)
  resellerId  String?       @db.Uuid
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  reseller    User?         @relation("ResellerTenants", fields: [resellerId], references: [id], onDelete: SetNull)
  members     TenantMember[]
  appointments Appointment[]
  notifications NotificationLog[]

  @@index([resellerId])
}

model TenantMember {
  id        String             @id @default(uuid()) @db.Uuid
  tenantId  String             @db.Uuid
  userId    String             @db.Uuid
  role      TenantRole
  status    TenantMemberStatus @default(ACTIVE)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  tenant    Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([userId, tenantId])
  @@index([tenantId, role])
}

model Appointment {
  id                      String            @id @default(uuid()) @db.Uuid
  tenantId                String            @db.Uuid
  userId                  String            @db.Uuid
  startsAt                DateTime
  endsAt                  DateTime
  status                  AppointmentStatus @default(SCHEDULED)
  notes                   String?
  externalCalendarEventId String?
  cancelledAt             DateTime?
  createdAt               DateTime          @default(now())
  updatedAt               DateTime          @updatedAt
  tenant                  Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user                    User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  notifications           NotificationLog[]

  @@index([tenantId, startsAt])
  @@index([tenantId, status])
  @@index([userId, startsAt])
  @@index([startsAt, endsAt])
}

model NotificationLog {
  id                String             @id @default(uuid()) @db.Uuid
  tenantId          String             @db.Uuid
  appointmentId     String             @db.Uuid
  channel           NotificationChannel
  status            NotificationStatus @default(QUEUED)
  template          String
  providerMessageId String?
  errorMessage      String?
  sentAt            DateTime?
  createdAt         DateTime           @default(now())
  tenant            Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  appointment       Appointment        @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([appointmentId, status])
  @@index([tenantId, status])
}
